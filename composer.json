{
    "name": "ludelix/framework",
    "description": "The Ludelix Framework - Modern PHP framework",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ludelix Team",
            "email": "team@ludelix.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0",
        "symfony/yaml": "^6.0",
        "doctrine/annotations": "^2.0",
        "ratchet/pawl": "^0.4",
        "open-telemetry/api": "^1.0",
        "promphp/prometheus_client_php": "^2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Ludelix\\": "src/"
        },
        "files": [
            "src/Core/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ludelix\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}